def read_abfss_text(path: str) -> str:
    """
    Reads a text file from an ABFSS (Azure Blob File System) path using Spark, returning its contents as a single string. 
    If the read fails for any reason, it returns a clearly marked error message instead of raising an exception.
    """
    try:
        df = spark.read.text(path)
        return "\n".join(row.value for row in df.collect())
    except Exception as e:
        return f"<<FAILED TO READ FILE: {e}>>"


def load_and_label_files(paths: list[str]) -> str:
    """
    Iterates through a list of file paths, reads each file’s contents, and formats them into labeled sections that include the file name and content. 
    The result is a single combined string where each file is clearly separated and identified—well-suited for downstream processing or LLM input.
    """
    sections = []

    for path in paths:
        print("Reading:", path)

        content = read_abfss_text(path)

        if "/Files/" in path:
            rel_path = path.split("/Files/", 1)[-1]
        else:
            rel_path = path

        section = f"""
==============================
FILE: {rel_path}
==============================
{content}
"""
        sections.append(section)

    return "\n".join(sections)

def extract_facts_from_file(path: str) -> list[str]:
    """
    Takes a file, chunks it up and passes the chunks to the open ai function to get model to pull out facts"
    Facts are aggregated into a list and returned
    """
    text = fs_read_text(path)

    chunks = chunk_text(
        text,
        target_tokens=TARGET_TOKENS,
        overlap_tokens=OVERLAP_TOKENS
    )

    facts = []

    for i, ch in enumerate(chunks):
        user_prompt = f"""
SOURCE FILE: {path}
CHUNK {i+1} OF {len(chunks)}

CONTENT:
{ch}
"""
        resp = aoai_chat(
            system=FACT_EXTRACTION_PROMPT,
            user=user_prompt
        )

        # normalize bullets
        for line in resp.splitlines():
            line = line.strip()
            if line.startswith("-"):
                facts.append(line)

        time.sleep(0.15)  # light throttle

    return facts

def extract_pipeline_facts(file_paths: list[str]) -> list[str]:
    """
    Takes a list of paths and starts sending the files to extract facts from them using the extract_facts_from_file function
    """
    all_facts = []

    for p in file_paths:
        print("Extracting facts from:", p)
        file_facts = extract_facts_from_file(p)
        all_facts.extend(file_facts)

    # De-duplicate deterministically
    return sorted(set(all_facts))

def list_files_abfss(path: str, extensions=None):
    """
    Recursively list files using full ABFSS path.
    Works across lakehouses and workspaces.
    We are going to send in the main pipeline folder and then this will find all of the files inside of it
    """

    hadoop_conf = spark._jsc.hadoopConfiguration()
    fs = spark._jvm.org.apache.hadoop.fs.FileSystem.get(hadoop_conf)

    stack = [spark._jvm.org.apache.hadoop.fs.Path(path)]
    files = []

    while stack:
        current = stack.pop()

        try:
            statuses = fs.listStatus(current)
        except Exception as e:
            print(f"⚠️ Cannot access: {current}")
            return []

        for status in statuses:
            if status.isDirectory():
                stack.append(status.getPath())
            else:
                file_path = str(status.getPath())

                if extensions:
                    ext = os.path.splitext(file_path.lower())[1]
                    if ext in extensions:
                        files.append(file_path)
                else:
                    files.append(file_path)

    return files

def generate_pipeline_doc(
    pipeline_name: str,
    facts: list[str]
) -> str:
    """
    Takes the facts from a pipeline and then turns them into a markdown file
    """
    facts_md = "\n".join(facts)

    user_prompt = f"""
PIPELINE NAME:
{pipeline_name}

FACTS:
{facts_md}
"""
    # Call model
    final_md = aoai_chat(
        system=PIPELINE_DOC_PROMPT,
        user=user_prompt
    )

    print("----- RAW MODEL OUTPUT PREVIEW -----")
    print(repr(final_md[:500]))

    # Fix escaped newline issue
    if "\\n" in final_md:
        final_md = final_md.replace("\\n", "\n")

    # Normalize excessive blank lines
    import re
    final_md = re.sub(r"\n{3,}", "\n\n", final_md)

    # Ensure file ends cleanly
    final_md = final_md.strip() + "\n"

    return final_md

