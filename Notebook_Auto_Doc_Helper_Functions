# ============================================================
# FABRIC FILESYSTEM HELPERS
# ============================================================
def _get_fs():
    """
    Return the Fabric filesystem utility object.

    Fabric notebooks may expose filesystem helpers through either:
      - notebookutils.mssparkutils.fs
      - mssparkutils.fs

    This wrapper makes the rest of the script runtime-agnostic.
    """
    try:
        from notebookutils import mssparkutils as nb_utils
        return nb_utils.fs
    except Exception:
        try:
            return mssparkutils.fs  # type: ignore
        except Exception as e:
            raise RuntimeError(
                "Could not find notebookutils/mssparkutils filesystem utilities."
            ) from e


FS = _get_fs()


def fs_mkdirs(path: str):
    """
    Create a directory path in the Fabric filesystem.

    This is intentionally tolerant:
    if the directory already exists or mkdirs throws in that situation,
    the exception is ignored.
    """
    try:
        FS.mkdirs(path)
    except Exception:
        # mkdirs can throw if the folder already exists in some runtimes
        pass


def fs_read_text(path: str) -> str:
    """
    Read a text file from the Fabric filesystem by first copying it locally.

    This works around the lack of a universal direct read-text helper
    in mssparkutils across environments.
    """
    tmp = f"/tmp/read_{int(time.time() * 1000)}"
    FS.cp(path, f"file:{tmp}")
    with open(tmp, "r", encoding="utf-8", errors="replace") as f:
        return f.read()


def fs_put_text(path: str, content: str, overwrite: bool = True):
    """
    Write a UTF-8 text file to the Fabric filesystem.

    Use this for files that can be decoded as text cleanly.
    """
    FS.put(path, content, overwrite)


def fs_put_bytes(path: str, b: bytes, overwrite: bool = True):
    """
    Write binary content to the Fabric filesystem.

    Why this helper exists:
    direct binary writes are not always reliable through FS.put, so this method:
      1. writes bytes to a local temp file
      2. copies that temp file into the Lakehouse using FS.cp

    This works well for binary files such as notebooks, images, archives, etc.
    """
    tmp = f"/tmp/{int(time.time() * 1000)}_{os.path.basename(path)}"

    with open(tmp, "wb") as f:
        f.write(b)

    if overwrite:
        try:
            FS.rm(path, True)
        except Exception:
            pass

    FS.cp(f"file:{tmp}", path)


