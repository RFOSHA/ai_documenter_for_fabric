def normalize_wiki_name(name: str) -> str:
    """
    Normalize a name so it is safer to use in wiki/page contexts.
    """
    return (
        name.replace(".", "_")
            .replace(" ", "_")
            .replace(":", "_")
    )


def wiki_create_or_update_page(
    page_path: str,
    content_md: str,
    comment: str = "Auto-generated Fabric documentation"
):
    """
    Create or update an Azure DevOps Wiki page with Markdown content.
    """
    base = f"https://dev.azure.com/{ORG}/{PROJECT}/_apis/wiki/wikis/{WIKI_ID_OR_NAME}/pages"

    params = {
        "path": page_path,
        "comment": comment,
        "api-version": "7.1",
    }

    headers = azdo_headers(AZDO_PAT)
    headers["Content-Type"] = "application/json"

    body = {"content": content_md}

    r = requests.put(base, headers=headers, params=params, json=body, timeout=60)
    r.raise_for_status()
    return r.json()


def ensure_wiki_page_exists(page_path: str):
    """
    Ensure a Wiki page exists by creating it if it is missing.

    Safe to call repeatedly.
    """
    url = (
        f"https://dev.azure.com/{AZDO_ORG}/{AZDO_PROJECT}"
        f"/_apis/wiki/wikis/{AZDO_WIKI_NAME}/pages"
    )

    # First check whether the page already exists
    r = requests.get(
        url,
        headers=azdo_headers(AZDO_PAT),
        params={
            "path": page_path,
            "api-version": "7.0"
        },
        timeout=30
    )

    if r.status_code == 200:
        return

    # If the page does not exist, create a minimal placeholder page
    if r.status_code == 404:
        create = requests.put(
            url,
            headers=azdo_headers(AZDO_PAT),
            params={
                "path": page_path,
                "api-version": "7.0",
                "comment": "Auto-created ancestor page"
            },
            json={
                "content": f"# {page_path.split('/')[-1]}\n\n_Auto-created container page._"
            },
            timeout=30
        )

        if create.status_code not in (200, 201):
            raise RuntimeError(
                f"Failed to create ancestor page {page_path}: "
                f"{create.status_code} - {create.text}"
            )

        return

    raise RuntimeError(
        f"Unexpected response checking page {page_path}: "
        f"{r.status_code} - {r.text}"
    )


def ensure_wiki_ancestors(full_page_path: str):
    """
    Ensure all parent Wiki pages exist.

    Example:
      /a/b/c -> ensures /a and /a/b exist
    """
    parts = full_page_path.strip("/").split("/")

    for i in range(1, len(parts)):
        ancestor = "/" + "/".join(parts[:i])
        ensure_wiki_page_exists(ancestor)


def get_wiki_page_etag(wiki_page_path: str) -> str | None:
    """
    Get the current ETag for a Wiki page.

    Azure DevOps uses the ETag for safe overwrite/update behavior.
    """
    url = (
        f"https://dev.azure.com/{AZDO_ORG}/{AZDO_PROJECT}"
        f"/_apis/wiki/wikis/{AZDO_WIKI_NAME}/pages"
    )

    r = requests.get(
        url,
        headers=azdo_headers(AZDO_PAT),
        params={
            "path": wiki_page_path,
            "api-version": "7.0"
        },
        timeout=30
    )

    if r.status_code == 200:
        return r.headers.get("ETag")

    if r.status_code == 404:
        return None

    raise RuntimeError(
        f"Failed to get wiki page {wiki_page_path}: "
        f"{r.status_code} - {r.text}"
    )


def read_markdown_from_lakehouse(md_path: str) -> str:
    """
    Read a markdown file stored in the Lakehouse.
    """
    return fs_read_text(md_path)


def publish_markdown_file_to_wiki(
    md_path: str,
    wiki_page_path: str,
    comment: str
):
    """
    Read a markdown file from the Lakehouse and publish it to the Azure DevOps Wiki.

    If the page already exists, its ETag is used so the update behaves as an
    intentional overwrite rather than an unsafe blind write.
    """
    markdown_content = fs_read_text(md_path)

    url = (
        f"https://dev.azure.com/{AZDO_ORG}/{AZDO_PROJECT}"
        f"/_apis/wiki/wikis/{AZDO_WIKI_NAME}/pages"
    )

    etag = get_wiki_page_etag(wiki_page_path)

    headers = {
        **azdo_headers(AZDO_PAT),
        "Content-Type": "application/json"
    }

    if etag:
        headers["If-Match"] = etag

    r = requests.put(
        url,
        headers=headers,
        params={
            "path": wiki_page_path,
            "comment": comment,
            "api-version": "7.0"
        },
        json={"content": markdown_content},
        timeout=60
    )

    if r.status_code not in (200, 201):
        raise RuntimeError(f"Wiki publish failed: {r.status_code} - {r.text}")

    return r.json()
