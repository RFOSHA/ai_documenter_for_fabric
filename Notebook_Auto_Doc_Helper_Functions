def download_item(repo_id: str, path: str) -> bytes:
    """
    Download the raw content of a single repository file.

    Parameters:
        repo_id: Azure DevOps repository ID
        path: repo-relative file path, such as '/notebooks/example.ipynb'

    Returns:
        Raw file bytes
    """
    url = f"https://dev.azure.com/{ORG}/{PROJECT}/_apis/git/repositories/{repo_id}/items"

    params = {
        "path": path,
        "includeContent": "true",
        "resolveLfs": "true",
        "versionDescriptor.versionType": "branch",
        "versionDescriptor.version": BRANCH.replace("refs/heads/", ""),
        "api-version": API_VERSION,
    }

    r = requests.get(url, headers=HEADERS, params=params, timeout=120)
    r.raise_for_status()
    return r.content


def dump_repo(repo: dict, max_files: int | None = None):
    """
    Export all files from a single Azure DevOps repository into the Lakehouse.

    Process:
    1. Create a base destination folder
    2. List all repo items
    3. Filter to actual files only (git blobs)
    4. Download each file
    5. Write text files as UTF-8 when possible
    6. Write non-text or undecodable files as binary

    Parameters:
        repo: repository metadata dictionary from Azure DevOps
        max_files: optional cap for testing/debugging
    """
    repo_name = repo["name"]
    repo_id = repo["id"]
    base_dir = safe_join(RAW_ROOT, PROJECT, repo_name)

    fs_mkdirs(base_dir)

    items = list_repo_items(repo_id)
    files = [i for i in items if i.get("gitObjectType") == "blob"]
    print(f"[{repo_name}] files: {len(files)}")

    count = 0

    for it in files:
        if max_files and count >= max_files:
            break

        path = it["path"]           # e.g. "/notebooks/foo.ipynb"
        rel = path.lstrip("/")
        dest = safe_join(base_dir, rel)

        # Ensure parent folder exists before writing the file
        parent = "/".join(dest.split("/")[:-1])
        if parent:
            fs_mkdirs(parent)

        try:
            blob = download_item(repo_id, path)

            if is_probably_text(path):
                # Best-effort UTF-8 decode; if not valid text, fall back to binary write
                try:
                    fs_put_text(dest, blob.decode("utf-8"), overwrite=True)
                except UnicodeDecodeError:
                    fs_put_bytes(dest, blob, overwrite=True)
            else:
                fs_put_bytes(dest, blob, overwrite=True)

            count += 1

            if count % 100 == 0:
                print(f"  wrote {count} files...")

        except Exception as e:
            print("ERROR:", repo_name, path, str(e)[:200])

    print(f"[{repo_name}] wrote {count} files to {base_dir}")


