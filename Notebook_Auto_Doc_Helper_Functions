# GENERAL UTILITY HELPERS
# ============================================================
def safe_join(*parts: str) -> str:
    """
    Join path segments using forward slashes.

    This normalizes:
    - leading/trailing slashes
    - Windows backslashes

    Example:
        safe_join("Files/devops_raw", "project", "/repo/path/file.py")
    becomes:
        Files/devops_raw/project/repo/path/file.py
    """
    return "/".join(
        [p.strip("/").replace("\\", "/") for p in parts if p is not None and p != ""]
    )


def estimate_tokens(s: str) -> int:
    """
    Get a rough approximation of how many tokens are in a body of text.
    """
    # Rough heuristic: ~4 characters per token
    return max(1, len(s) // 4)


def chunk_text(
    s: str,
    target_tokens: int = 900,
    overlap_tokens: int = 100
) -> list[str]:
    """
    Split a large string into overlapping chunks sized approximately by token count.

    This is useful for sending long content to LLMs while preserving enough
    overlap between chunks for continuity.
    """
    target_chars = target_tokens * 4
    overlap_chars = overlap_tokens * 4

    chunks = []
    i = 0

    while i < len(s):
        j = min(len(s), i + target_chars)
        chunk = s[i:j]
        chunks.append(chunk)

        if j == len(s):
            break

        i = max(0, j - overlap_chars)

    return chunks


def is_probably_text(path: str) -> bool:
    """
    Return True if the file extension suggests this is a text-based file.

    This helps decide whether to:
    - decode bytes and write as UTF-8 text
    - or preserve raw bytes and write as binary
    """
    ext = path.lower().split(".")[-1] if "." in path else ""
    return ext in {
        "py", "ipynb", "sql", "md", "txt", "json", "yml", "yaml",
        "toml", "ini", "cfg", "xml", "csv", "ts", "js", "css",
        "html", "pbip", "pbir"
    }


